# Copy to `.env` in this same folder (flood_triage_agent/).

# FASTEST path for local dev/demo -- a Google AI Studio API key:
GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_API_KEY=your-gemini-api-key

# For your submission to genuinely count Gemini Enterprise Agent Platform
# as a GCP-layer technology (not just "an API key"), switch to Vertex
# AI-backed auth instead before your final demo/submission:
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# (requires `gcloud auth application-default login` and the Vertex AI API
# enabled on that project)
