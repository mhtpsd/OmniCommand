# Copy this file to `.env.local` in the same folder and fill in real values.
# Next.js only exposes vars prefixed NEXT_PUBLIC_ to browser-side code.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live

# Free tier available at https://account.mapbox.com/ -- needed for MapView.tsx
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here
