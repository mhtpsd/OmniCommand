# Copy this file to `.env` in the same folder and fill in real values.
# config.py loads all of these -- do not commit the real .env file.

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=urban-sensor-events
KAFKA_CONSUMER_GROUP=analytics-engine

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Google Cloud / BigQuery ---
# Create a project in GCP console, enable the BigQuery API, and create a
# dataset + table before running bigquery_client.py (see TODO in that file).
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=omnicommand
BIGQUERY_TABLE=sensor_risk_history
# Path to a service-account JSON key with BigQuery Data Editor role.
# Alternatively, run `gcloud auth application-default login` locally and
# leave this blank.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Gemini ---
# Get a key from Google AI Studio, or use Vertex AI service-account auth.
GEMINI_API_KEY=your-gemini-api-key
# Verify current model availability before the demo -- names change often.
# As of mid-2026, gemini-2.5-flash (fast/cheap) or gemini-3.1-pro (higher
# accuracy on complex scenes) are reasonable choices. Gemini 1.5 models are
# fully retired -- do not use them.
GEMINI_MODEL=gemini-2.5-flash

# --- Micro-batching ---
# How often the Kafka consumer flushes buffered events into a batch for
# risk_scoring.py to process. Lower = more "real-time" but more overhead.
BATCH_WINDOW_SECONDS=3
